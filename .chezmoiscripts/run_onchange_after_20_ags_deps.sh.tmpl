{{- if eq .chezmoi.osRelease.id "arch" -}}
#!/bin/bash
# package.json hash: {{ include "private_dot_config/private_ags/package.json" | sha256sum }}
# tsconfig.json hash: {{ include "private_dot_config/private_ags/tsconfig.json" | sha256sum }}

# Generate AGS type definitions (@girs/)
AGS_DIR={{ joinPath .chezmoi.homeDir ".config/ags" | quote }}

if [ -d "$AGS_DIR" ] && command -v ags &> /dev/null; then
    echo "Generating AGS types..."
    ags types -d "$AGS_DIR"
else
    echo "AGS not found or directory missing, skipping type generation"
fi

{{- end -}}
